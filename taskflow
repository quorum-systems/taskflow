def _load_config_categories() -> List[str]:
    return [c["name"] for c in get_categories()]


def cmd_progress(as_json: bool = False) -> int:
    sys.path.insert(0, str(SCRIPTS_DIR))
    from reports import report_progress
    root  = git_root()
    cats  = _load_config_categories()
    icons = {c["name"]: c.get("icon", "") for c in get_categories()}
    states_cfg = {k: get_state(k) for k in STATE_DEFAULTS}
    print(report_progress(root, config_categories=cats or None,
                          as_json=as_json, state_icons=icons, states=states_cfg))
    return 0


def cmd_pipeline(as_json: bool = False) -> int:
    sys.path.insert(0, str(SCRIPTS_DIR))
    from reports import report_pipeline
    root  = git_root()
    cats  = _load_config_categories()
    icons = {c["name"]: c.get("icon", "") for c in get_categories()}
