# ---------------------------------------------------------------------------
# Setup command
# ---------------------------------------------------------------------------

def cmd_setup(force: bool = False, dry_run: bool = False) -> int:
    try:
        import yaml
    except ImportError:
        print("error: PyYAML is required.  Run: pip install pyyaml", file=sys.stderr)
        return 1

    if not CONFIG_PATH.exists():
        print(f"error: {CONFIG_PATH.name} not found.", file=sys.stderr)
        return 1

    with CONFIG_PATH.open(encoding="utf-8") as f:
        cfg = yaml.safe_load(f) or {}

    errors = _validate_config(cfg)
    if errors:
        print("configuration errors in .taskflow.yml:", file=sys.stderr)
        for e in errors:
            print(f"  - {e}", file=sys.stderr)
        return 1

    categories = cfg.get("categories", [])
    phases     = cfg.get("phases", [])
    settings   = cfg.get("settings", {})
    repo_name  = settings.get("repo_name", "taskflow")

    print(f"\ntaskflow setup — {repo_name}")
    print(f"  {len(categories)} categories, {len(phases)} phases\n")

    changed = []
    skipped = []

    SIMPLE_STATES = ["now", "blocked", "paused", "next"]
    SIMPLE_TITLES = {
        "now":     ("Now",     "Tasks actively being executed this week."),
        "blocked": ("Blocked", "Tasks waiting on something external.\n\nEach entry should have a note explaining what it's blocked on."),
        "paused":  ("Paused",  "Tasks deliberately on hold.\n\nNot blocked, not forgotten — just not now."),
        "next":    ("Next",    "Planned work queued for the next execution window."),
    }

    for state_name in SIMPLE_STATES:
        s     = get_state(state_name)
        path  = REPO_ROOT / s["file"]
        title, description = SIMPLE_TITLES[state_name]
        content = _build_simple_file(title, description, categories)
        if not dry_run:
            path.parent.mkdir(parents=True, exist_ok=True)
        if path.exists() and not force:
            skipped.append(s["file"])
        else:
            if not dry_run:
                path.write_text(content, encoding="utf-8")
            changed.append(s["file"])

    later_s    = get_state("later")
    later_path = REPO_ROOT / later_s["file"]
    later_content = _build_later_file(categories, phases)
    if not dry_run:
        later_path.parent.mkdir(parents=True, exist_ok=True)
    if later_path.exists() and not force:
        skipped.append(later_s["file"])
    else:
        if not dry_run:
            later_path.write_text(later_content, encoding="utf-8")
        changed.append(later_s["file"])

    done_s    = get_state("done")
    done_path = REPO_ROOT / done_s["file"]
    if not dry_run:
        done_path.parent.mkdir(parents=True, exist_ok=True)
    if not done_path.exists():
        if not dry_run:
            done_path.write_text(
                "# Done\n\nCompleted tasks, appended by `taskflow done`.\n\n---\n",
                encoding="utf-8",
            )
        changed.append(done_s["file"])

    weekly_dir = REPO_ROOT / settings.get("weekly_plan_dir", "changelog/weekly")
    if not weekly_dir.exists():
        if not dry_run:
            weekly_dir.mkdir(parents=True, exist_ok=True)
            (weekly_dir / ".gitkeep").touch()
        changed.append(str(weekly_dir.relative_to(REPO_ROOT)) + "/")

    week_plan_path = SCRIPTS_DIR / "week-plan"
    if _patch_week_plan(week_plan_path, categories, dry_run):
        changed.append("scripts/git/week-plan")
        print("  updated  scripts/git/week-plan (category config)")

    _install_git_aliases(dry_run)

    if changed:
        print("  created/updated:")
        for f in changed:
            print(f"    + {f}")
    if skipped:
        print("  skipped (already exist — use --force to overwrite):")
        for f in skipped:
            print(f"    ~ {f}")

    print(f"\n  Done. Edit .taskflow.yml and re-run `taskflow setup` to regenerate.\n")
    return 0


# ---------------------------------------------------------------------------
# Setup internals
# ---------------------------------------------------------------------------

def _validate_config(cfg: dict) -> list:
    errors = []
    for i, cat in enumerate(cfg.get("categories", [])):
        if not cat.get("name"):
            errors.append(f"categories[{i}] is missing 'name'")
    cat_names = {c["name"] for c in cfg.get("categories", [])}
    for i, phase in enumerate(cfg.get("phases", [])):
        if not phase.get("name"):
            errors.append(f"phases[{i}] is missing 'name'")
        for c in phase.get("categories", []):
            if c not in cat_names:
                errors.append(f"phases[{i}] references unknown category '{c}'")
    return errors


def _category_heading(cat: dict) -> str:
    icon = cat.get("icon", "")
    name = cat["name"]
    return f"### {icon} {name}".strip() if icon else f"### {name}"


def _build_simple_file(title: str, description: str, categories: list) -> str:
    lines = [f"# {title}", "", description.strip(), ""]
    for cat in categories:
        lines.append("---")
        lines.append("")
        lines.append(_category_heading(cat))
        lines.append("")
    lines.append("---")
    return "\n".join(lines) + "\n"


def _build_later_file(categories: list, phases: list) -> str:
    cat_by_name = {c["name"]: c for c in categories}
    lines = [
        "# Later", "",
        "Longer-horizon work organised by phase.", "",
        "Promote to next when the time is right:", "",
        "```", 'taskflow promote "task text"', "```", "",
    ]
    for phase in phases:
        lines += ["---", "", f"## {phase['name']}"]
        if phase.get("description"):
            lines += ["", f"> {phase['description']}"]
        lines.append("")
        phase_cat_names = phase.get("categories") or [c["name"] for c in categories]
        for cat_name in phase_cat_names:
            cat = cat_by_name.get(cat_name)
            if cat:
                lines += [_category_heading(cat), ""]
    lines.append("---")
    return "\n".join(lines) + "\n"


WEEK_PLAN_BLOCK_START = "# === TASKFLOW GENERATED — do not edit below this line ==="
WEEK_PLAN_BLOCK_END   = "# === END TASKFLOW GENERATED ==="


def _build_week_plan_block(categories: list) -> str:
    lines = ["CATEGORY_ALIASES = {"]
    for cat in categories:
        name = cat["name"]
        for alias in cat.get("aliases", []):
            lines.append(f"    {alias!r}: {name!r},")
        lines.append(f"    {name!r}: {name!r},")
    lines.append("}")
    order = "DEFAULT_CATEGORY_ORDER = [\n" + "".join(f"    {c['name']!r},\n" for c in categories) + "]"
    return f"{WEEK_PLAN_BLOCK_START}\n" + "\n".join(lines) + f"\n\n{order}\n{WEEK_PLAN_BLOCK_END}\n"


def _patch_week_plan(path: Path, categories: list, dry_run: bool) -> bool:
    if not path.exists():
        return False
    content = path.read_text(encoding="utf-8")
    new_block = _build_week_plan_block(categories)
    if WEEK_PLAN_BLOCK_START in content:
        import re as _re
        pattern = _re.compile(
            re.escape(WEEK_PLAN_BLOCK_START) + r".*?" + re.escape(WEEK_PLAN_BLOCK_END) + r"\n?",
            _re.DOTALL,
        )
        new_content = pattern.sub(new_block, content)
    else:
        new_content = content.rstrip() + "\n\n" + new_block
    if new_content == content:
        return False
    if not dry_run:
        path.write_text(new_content, encoding="utf-8")
    return True


def _install_git_aliases(dry_run: bool) -> None:
    aliases_path = REPO_ROOT / "scripts" / "git-aliases.sh"
    if not aliases_path.exists():
        return
    if dry_run:
        print("  [dry-run] would run: scripts/git-aliases.sh")
        return
    result = subprocess.run([str(aliases_path)], capture_output=True, text=True)
    if result.returncode != 0:
        print(f"  warning: git-aliases.sh exited {result.returncode}", file=sys.stderr)
        if result.stderr:
            print(result.stderr, file=sys.stderr)


# ---------------------------------------------------------------------------
# Argument parser
# ---------------------------------------------------------------------------

def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="taskflow",
        description="Git-native task management.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
commands:
  setup                    generate backlog files and install git aliases
  promote <task>           later   → next
  start   <task>           next    → now
  block   <task>           now     → blocked
  unblock <task>           blocked → now
  pause   <task>           now     → paused
  unpause <task>           paused  → now
  backlog <task>           now     → next
  done    <task>           now     → done + commit
  add <state> <cat> <task> add task directly to any state
  status                   active tasks, blockers, holds
  week                     this week's completions
  pipeline [--json]        work in flight across all states
  progress [--json]        now vs. done counts by week

task matching is fuzzy — you only need enough text to be unique.
git aliases call this script directly; both paths are equivalent.
        """,
    )
    sub = parser.add_subparsers(dest="command", metavar="command")

    p_setup = sub.add_parser("setup")
    p_setup.add_argument("--force",   action="store_true")
    p_setup.add_argument("--dry-run", action="store_true")

    for cmd in list(WORKFLOW_TRANSITIONS.keys()) + ["done"]:
        p = sub.add_parser(cmd)
        p.add_argument("task", nargs="+")

    p_add = sub.add_parser("add")
    p_add.add_argument("state",    help="target state (now, next, later, blocked, paused, done)")
    p_add.add_argument("category", help="category name (fuzzy matched)")
    p_add.add_argument("task",     nargs="+", help="task text")

    sub.add_parser("status")
    sub.add_parser("week")

    p_progress = sub.add_parser("progress")
    p_progress.add_argument("--json", action="store_true", dest="as_json")

    p_pipeline = sub.add_parser("pipeline")
    p_pipeline.add_argument("--json", action="store_true", dest="as_json")

    return parser


def main() -> int:
    parser = build_parser()
    args   = parser.parse_args()

    if not args.command:
        parser.print_help()
        return 0

    if args.command == "setup":
        return cmd_setup(force=args.force, dry_run=args.dry_run)

    if args.command == "status":
        return cmd_status()

    if args.command == "week":
        return cmd_week()

    if args.command == "progress":
        return cmd_progress(as_json=args.as_json)

    if args.command == "pipeline":
        return cmd_pipeline(as_json=args.as_json)

    if args.command == "add":
        return cmd_add(args.state, args.category, " ".join(args.task))

    task = " ".join(args.task)

    if args.command == "done":
        return cmd_done(task)

    if args.command in WORKFLOW_TRANSITIONS:
        return cmd_workflow(args.command, task)

    parser.print_help()
    return 1


if __name__ == "__main__":
    raise SystemExit(main())